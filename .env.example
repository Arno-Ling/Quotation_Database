# 数据库路径配置
# 请将此文件复制为 .env 并修改为您的实际数据库路径

# Windows路径示例（使用正斜杠或双反斜杠）:
# DATABASE_PATH=C:/Users/YourName/Desktop/Database
# DATABASE_PATH=C:\\Users\\YourName\\Desktop\\Database

# Linux/Mac路径示例:
# DATABASE_PATH=/home/username/Database
# DATABASE_PATH=/Users/username/Desktop/Database

# 相对路径示例（相对于docker-compose.yml所在目录）:
# DATABASE_PATH=./Database

# 请在下方填写您的数据库路径
DATABASE_PATH=./Database
